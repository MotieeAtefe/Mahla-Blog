@{
    var selected = ViewData["selected"]?.ToString()?.ToLower();
}
<aside class="main-sidebar">
    <section class="sidebar">

        <ul class="sidebar-menu" data-widget="tree">
            <li class="@(selected == "index" ? "active" : null)">
                <a asp-area="Admin" asp-controller="Home" asp-action="index">
                    <i class="fa fa-dashboard"></i> <span>داشبرد</span>

                </a>
            </li>
            <li class="@(selected == "category" ? "active" : null)">

                <a asp-area="Admin" asp-controller="Category" asp-action="Index">
                    <i class="fa fa-th"></i> <span>دسته بندی ها</span>

                </a>
            </li>
            <li class="@(selected == "Post" ? "active" : null)">

                <a asp-area="Admin" asp-controller="Post" asp-action="Index">
                    <i class="fa fa-th"></i> <span>مقالات</span>

                </a>
            </li>
        </ul>
    </section>
</aside>