@model Mahla_Blog.Web.Areas.Admin.Models.Posts.CreatePostViewModel
@using Mahla_Blog.CoreLayer.Services.Categories
@inject ICategoryService _categoryService;
@{
    ViewData["Title"] = "افزودن مقاله";
    var categorie = _categoryService.GetAllCategories();
}

<section class="content-header">
    <h1>
        @ViewData["title"]
    </h1>

    <ol class="breadcrumb">
        <li><a asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="fa fa-dashboard"></i> خانه</a></li>
        <li><a asp-area="Admin" asp-controller="Post" asp-action="Index"></a></li>
        <li class="active">@ViewData["title"]</li>
    </ol>
</section>
<section>
    <form class="box box-danger" method="post" asp-area="admin" asp-controller="Post" asp-action="Add">
        <div class="box-body row">
            <div class="col-md-6">
                @Html.EditorFor(m => m.Title)
            </div>
            <div class="col-md-6">
                @Html.EditorFor(m => m.Slug)
            </div>
            <div class="col-md-12">
                @Html.EditorFor(m => m.Description)
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="CategoryId"></label>
                    <select asp-for="CategoryId" class="form-control">
                        @foreach (var item in categorie.Where(p => p.ParentId == null))
                        {
                            <option value="@item.Id">@item.Title</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label asp-for="SubCategoryId"></label>
                    <select asp-for="SubCategoryId" class="form-control"></select>
                    <span asp-validation-for="SubCategoryId"></span>
                </div>
            </div>
            <div class="col-md-12">
                @Html.EditorFor(m => m.ImageFile)
            </div>

        </div>
        <div class="box-footer">
            <button class="btn btn-success" type="submit">ثبت اطلاعات</button>
        </div>
    </form>
</section>
@section Scripts
{
    <script>
        $("#CategoryId").change(function () {
            var categoryId = $(this).val();
            $.ajax({
                url:"Admin/Category/GetChildCategories?parentid=" + categoryId,
                type:"get"

            }).done(function(data)
            {
                console.log(data);
            });

        });
    </script>
}


