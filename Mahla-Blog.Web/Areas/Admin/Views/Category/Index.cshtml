@model List<Mahla_Blog.CoreLayer.DTOs.Categories.CategoriesDto>
@{
    ViewData["Title"] = "دسته بندی ها";
    ViewData["selected"] = "category";
    var Counter = 1;
}

<section class="content-header">
    <h1>
        @ViewData["title"]
    </h1>
    <ol class="breadcrumb">
        <li><a asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="fa fa-dashboard"></i> خانه</a></li>
        <li><a asp-area="Admin" asp-controller="Category" asp-action="Index">دسته بندی ها</a></li>
        <li class="active">@ViewData["title"]</li>
    </ol>
</section>

<section class="content">
    <a class="btn btn-success" style="margin-bottom:5px;" asp-area="Admin" asp-action="Add" asp-controller="Category">افزودن گروه جدید</a>
    <div class="box box-primary">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>عنوان</th>
                    <th>زیرگروه</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model.Where(p => p.ParentId == null))
                {
                    <tr>
                        <td>@Counter</td>
                        <td>@item.Title</td>
                        <td>

                            @if (Model.Any(p => p.ParentId == item.id))
                            {
                                <ul>
                                    @foreach (var subCategory in Model.Where(p => p.ParentId == item.id))
                                    {
                                        <li>
                                            @subCategory.Title
                                            <a asp-area="Admin" asp-controller="Category" asp-action="Edit" asp-route-id="@item.id" class="btn btn-info btn-sm">ویرایش</a>
                                        </li>

                                    }
                                </ul>
                            }

                        </td>
                        <td>
                            <a asp-area="Admin" asp-controller="Category" asp-action="Edit" asp-route-id="@item.id" class="btn btn-info btn-sm">ویرایش</a>
                            <a asp-area="Admin" asp-controller="Category" asp-action="Add" asp-route-parentId="@item.id" class="btn btn-success btn-sm">افزودن زیر گروه</a>

                        </td>
                    </tr>
                    Counter++;
                }
            </tbody>
        </table>
    </div>
</section>